{
  "name": "claude-loom",
  "version": "0.13.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "pnpm --filter @claude-loom/daemon test && bash tests/run_tests.sh",
    "test:harness": "bash tests/run_tests.sh",
    "test:daemon": "pnpm --filter @claude-loom/daemon test",
    "dev": "pnpm --filter @claude-loom/daemon dev",
    "build": "pnpm -r build"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
