{
  "$schema": "https://claude-loom.dev/schemas/project-v1.json",
  "schema_version": 1,

  "project_id": "PLACEHOLDER_UUID",
  "name": "PLACEHOLDER_PROJECT_NAME",

  "spec_path": "SPEC.md",
  "plan_path": "PLAN.md",
  "related_docs": [
    "README.md",
    "CLAUDE.md",
    "docs/**/*.md",
    "tests/REQUIREMENTS.md"
  ],

  "methodology": "agile",

  "pool": {
    "max_developers": 3,
    "max_reviewers": 1,
    "max_code_reviewers": 1,
    "max_security_reviewers": 1,
    "max_test_reviewers": 1
  },

  "rules": {
    "tdd_required": true,
    "branch_pattern": "<type>/{short-kebab-name}",
    "branch_types": ["feat", "fix", "docs", "style", "refactor", "perf", "test", "build", "ci", "chore"],
    "commit_prefixes": ["feat", "fix", "docs", "style", "refactor", "perf", "test", "build", "ci", "chore", "revert"],
    "commit_language": "any",
    "main_branch": "main",
    "no_direct_commit_to_main": true,
    "review_mode": "single",
    "_coexistence_comment": "M0.12 から有効。mode: full=全機能 ON / coexist=core のみ / custom=enabled_features 指定。詳細 SPEC §3.6.7。",
    "coexistence_mode": "full",
    "enabled_features": ["all"]
  },

  "consistency_engine": {
    "trigger_mode": "manual",
    "regex_screen_enabled": true,
    "llm_analysis_enabled": true
  }
}
