{
  "$schema": "https://claude-loom.dev/schemas/project-prefs-v1.json",
  "schema_version": 1,

  "lenses": {},

  "auto_apply": {
    "categories": [],
    "max_risk": "never"
  },

  "last_retro": {
    "id": "",
    "milestone": "",
    "completed_at": 0
  },

  "learned_patterns": {
    "common_blockers": [],
    "frequent_finding_categories": []
  },

  "agents": {
    "_comment": "PJ 単位の override。user-prefs より優先される。詳細: SPEC §6.9.4",
    "loom-developer": {
      "model": "sonnet",
      "personality": "default"
    }
  },

  "worktree": {
    "_comment": "M0.10 から有効。base_path placeholder {branch} は branch slug に置換、auto_cleanup は v1 では false 固定、max_concurrent は自律発動の暴走防止上限",
    "base_path": "<parent>/<repo>-{branch}",
    "auto_cleanup": false,
    "max_concurrent": 5
  }
}
